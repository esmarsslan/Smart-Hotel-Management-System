<div class="stat-grid">
  <div class="stat-card">
    <div class="stat-label">Total Rooms</div>
    <div class="stat-value"><%= total_rooms %></div>
    <div class="stat-detail"><%= cleaning_rooms %> rooms being cleaned</div>
  </div>
  <div class="stat-card accent-blue">
    <div class="stat-label">Occupancy Rate</div>
    <div class="stat-value">%<%= occupancy_rate %></div>
    <div class="stat-detail"><%= occupied_rooms %> / <%= total_rooms %> rooms occupied</div>
  </div>
  <div class="stat-card accent-green">
    <div class="stat-label">Active Guests</div>
    <div class="stat-value"><%= active_guests %></div>
    <div class="stat-detail">Currently staying</div>
  </div>
  <div class="stat-card accent-amber">
    <div class="stat-label">Total Revenue</div>
    <div class="stat-value">₺<%= formatCurrency(total_revenue) %></div>
    <div class="stat-detail">Confirmed payments</div>
  </div>
</div>

<div class="secondary-stat-grid">
  <div class="secondary-stat">
    <span class="sec-label">Today's Check-in</span>
    <span class="sec-value blue"><%= today_checkins %></span>
  </div>
  <div class="secondary-stat">
    <span class="sec-label">Today's Check-out</span>
    <span class="sec-value orange"><%= today_checkouts %></span>
  </div>
  <div class="secondary-stat">
    <span class="sec-label">Available Rooms</span>
    <span class="sec-value green"><%= available_rooms %></span>
  </div>
  <div class="secondary-stat">
    <span class="sec-label">Cleaning</span>
    <span class="sec-value gray"><%= cleaning_rooms %></span>
  </div>
</div>

<div class="card-section">
  <div class="section-header">
    <h2 class="section-title">Recent Reservations</h2>
    <a href="/reservations" class="section-link">View all →</a>
  </div>
  <div class="table-wrapper">
    <table class="data-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Guest</th>
          <th>Room</th>
          <th>Check-in</th>
          <th>Check-out</th>
          <th>Amount</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% recent_reservations.forEach((res) => { %>
          <tr>
            <td class="mono">#<%= 1000 + res.id %></td>
            <td><%= res.first_name %> <%= res.last_name %></td>
            <td><%= res.room_number %> <span class="room-type-tag"><%= res.room_type %></span></td>
            <td><%= formatDateShort(res.check_in_date) %></td>
            <td><%= formatDateShort(res.check_out_date) %></td>
            <td class="mono">₺<%= formatCurrency(res.total_amount) %></td>
            <td>
              <% if (res.status === "confirmed") { %><span class="badge badge-blue">Confirmed</span>
              <% } else if (res.status === "checked_in") { %><span class="badge badge-green">Check-in</span>
              <% } else if (res.status === "checked_out") { %><span class="badge badge-gray">Check-out</span>
              <% } else if (res.status === "cancelled") { %><span class="badge badge-red">Cancelled</span><% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
