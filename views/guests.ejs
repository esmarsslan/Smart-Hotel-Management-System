<form method="GET" action="/guests" class="search-bar">
  <input type="text" name="search" value="<%= search %>" placeholder="Search by first name, last name, or ID..." class="search-input">
  <button type="submit" class="btn-primary-custom">Search</button>
  <% if (search) { %><a href="/guests" class="btn-secondary-custom">Clear</a><% } %>
</form>

<div class="card-section">
  <div class="table-wrapper">
    <table class="data-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Full Name</th>
          <th>ID / Passport</th>
          <th>Phone</th>
          <th>Email</th>
          <th>Nationality</th>
          <th>Registration Date</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (guests.length === 0) { %>
          <tr>
            <td colspan="8" style="text-align:center; padding: 32px; color: var(--text-muted);">
              <%= search ? "No search results found." : "No guest records yet." %>
            </td>
          </tr>
        <% } %>
        <% guests.forEach((guest) => { %>
          <tr>
            <td class="mono">#<%= guest.id %></td>
            <td>
              <div class="guest-name-cell">
                <div class="guest-avatar"><%= guest.first_name[0] %><%= guest.last_name[0] %></div>
                <%= guest.first_name %> <%= guest.last_name %>
              </div>
            </td>
            <td class="mono"><%= guest.id_number || "-" %></td>
            <td><%= guest.phone || "-" %></td>
            <td><%= guest.email || "-" %></td>
            <td><%= guest.nationality || "-" %></td>
            <td><%= formatDate(guest.created_at) %></td>
            <td>
              <% if (canDeleteGuest) { %>
                <form method="POST" action="/guests/delete/<%= guest.id %>" onsubmit="return confirm('Are you sure you want to delete this guest?')">
                  <button type="submit" class="btn-icon-danger">✕</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<div class="modal-overlay" id="addGuestModal" style="display:none;">
  <div class="modal-box">
    <div class="modal-header">
      <h3>New Guest Registration</h3>
      <button class="modal-close" onclick="closeModal('addGuestModal')">✕</button>
    </div>
    <form method="POST" action="/guests">
      <div class="form-row-2">
        <div class="form-group-custom">
          <label>First Name</label>
          <input type="text" name="first_name" class="form-control-custom" placeholder="Mehmet" required>
        </div>
        <div class="form-group-custom">
          <label>Last Name</label>
          <input type="text" name="last_name" class="form-control-custom" placeholder="Kaya" required>
        </div>
      </div>
      <div class="form-row-2">
        <div class="form-group-custom">
          <label>ID / Passport No</label>
          <input type="text" name="id_number" class="form-control-custom" placeholder="12345678901">
        </div>
        <div class="form-group-custom">
          <label>Phone</label>
          <input type="text" name="phone" class="form-control-custom" placeholder="0532 xxx xx xx">
        </div>
      </div>
      <div class="form-row-2">
        <div class="form-group-custom">
          <label>Email</label>
          <input type="email" name="email" class="form-control-custom" placeholder="guest@email.com">
        </div>
        <div class="form-group-custom">
          <label>Nationality</label>
          <input type="text" name="nationality" class="form-control-custom" placeholder="Turkiye" value="Turkiye">
        </div>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn-secondary-custom" onclick="closeModal('addGuestModal')">Cancel</button>
        <button type="submit" class="btn-primary-custom">Save Guest</button>
      </div>
    </form>
  </div>
</div>
