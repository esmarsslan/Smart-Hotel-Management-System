<div class="stat-grid" style="grid-template-columns: repeat(3, 1fr);">
  <div class="stat-card accent-green">
    <div class="stat-label">Total Collected</div>
    <div class="stat-value">₺<%= formatCurrency(total_paid) %></div>
    <div class="stat-detail">Confirmed payments</div>
  </div>
  <div class="stat-card accent-amber">
    <div class="stat-label">Pending Payments</div>
    <div class="stat-value">₺<%= formatCurrency(total_pending) %></div>
    <div class="stat-detail">Not collected yet</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Total Transactions</div>
    <div class="stat-value"><%= payments.length %></div>
    <div class="stat-detail">Recorded payments</div>
  </div>
</div>

<div class="card-section">
  <div class="table-wrapper">
    <table class="data-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Reservation</th>
          <th>Guest</th>
          <th>Amount</th>
          <th>Method</th>
          <th>Date</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% if (payments.length === 0) { %>
          <tr>
            <td colspan="7" style="text-align:center; padding: 32px; color: var(--text-muted);">No payment records found.</td>
          </tr>
        <% } %>
        <% payments.forEach((payment) => { %>
          <tr>
            <td class="mono">#<%= payment.id %></td>
            <td class="mono">#<%= 1000 + payment.reservation_id %></td>
            <td><%= payment.first_name %> <%= payment.last_name %></td>
            <td class="mono"><strong>₺<%= formatCurrency(payment.amount) %></strong></td>
            <td>
              <% if (payment.method === "card") { %><span class="method-tag card">Credit Card</span>
              <% } else if (payment.method === "cash") { %><span class="method-tag cash">Cash</span>
              <% } else { %><span class="method-tag transfer">Transfer</span><% } %>
            </td>
            <td><%= payment.paid_at ? formatDateTime(payment.paid_at) : "-" %></td>
            <td>
              <% if (payment.status === "paid") { %><span class="badge badge-green">Paid</span>
              <% } else if (payment.status === "pending") { %><span class="badge badge-orange">Pending</span>
              <% } else { %><span class="badge badge-red">Refunded</span><% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<div class="modal-overlay" id="addPayModal" style="display:none;">
  <div class="modal-box">
    <div class="modal-header">
      <h3>Record Payment</h3>
      <button class="modal-close" onclick="closeModal('addPayModal')">✕</button>
    </div>
    <form method="POST" action="/payments">
      <div class="form-group-custom">
        <label>Reservation</label>
        <select name="reservation_id" class="form-control-custom" required>
          <option value="">- Select Reservation -</option>
          <% pending_reservations.forEach((res) => { %>
            <option value="<%= res.id %>">#<%= 1000 + res.id %> - <%= res.first_name %> <%= res.last_name %> (₺<%= formatCurrency(res.total_amount || 0) %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="form-row-2">
        <div class="form-group-custom">
          <label>Amount (₺)</label>
          <input type="number" name="amount" class="form-control-custom" placeholder="1500" required>
        </div>
        <div class="form-group-custom">
          <label>Payment Method</label>
          <select name="method" class="form-control-custom">
            <option value="card">Credit Card</option>
            <option value="cash">Cash</option>
            <option value="transfer">Transfer</option>
          </select>
        </div>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn-secondary-custom" onclick="closeModal('addPayModal')">Cancel</button>
        <button type="submit" class="btn-primary-custom">Save Payment</button>
      </div>
    </form>
  </div>
</div>
