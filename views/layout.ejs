<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle || "Grand Hotel" %> - Yonetim Paneli</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <div class="sidebar-brand">
        <div class="brand-icon">GH</div>
        <div>
          <div class="brand-name">Grand Hotel</div>
          <div class="brand-sub">Yonetim Paneli</div>
        </div>
      </div>

      <%
        const role = currentUser?.role;
        const canSeeFrontDesk = role === "manager" || role === "receptionist";
      %>
      <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-link <%= currentPath === '/dashboard' ? 'active' : '' %>">
          <span class="nav-icon">⬡</span> Dashboard
        </a>
        <a href="/rooms" class="nav-link <%= currentPath === '/rooms' ? 'active' : '' %>">
          <span class="nav-icon">⬡</span> Odalar
        </a>
        <% if (canSeeFrontDesk) { %>
          <a href="/guests" class="nav-link <%= currentPath === '/guests' ? 'active' : '' %>">
            <span class="nav-icon">⬡</span> Misafirler
          </a>
          <a href="/reservations" class="nav-link <%= currentPath === '/reservations' ? 'active' : '' %>">
            <span class="nav-icon">⬡</span> Rezervasyonlar
          </a>
          <a href="/checkin" class="nav-link <%= currentPath === '/checkin' ? 'active' : '' %>">
            <span class="nav-icon">⬡</span> Check-in / Out
          </a>
          <a href="/payments" class="nav-link <%= currentPath === '/payments' ? 'active' : '' %>">
            <span class="nav-icon">⬡</span> Odemeler
          </a>
        <% } %>
      </nav>

      <div class="sidebar-footer">
        <div class="user-info">
          <div class="user-avatar"><%= currentUser?.full_name ? currentUser.full_name[0] : "U" %></div>
          <div>
            <div class="user-name"><%= currentUser?.full_name || "Kullanici" %></div>
            <div class="user-role">
              <%
                const roleLabels = {
                  manager: "Mudur",
                  receptionist: "Resepsiyon",
                  housekeeping: "Temizlik"
                };
              %>
              <%= roleLabels[currentUser?.role] || "Kullanici" %>
            </div>
          </div>
        </div>
        <a href="/logout" class="logout-btn">Cikis</a>
      </div>
    </aside>

    <main class="main-content">
      <div class="topbar">
        <div>
          <h1 class="page-title"><%= pageTitle || "" %></h1>
          <p class="page-sub"><%= pageSub || "" %></p>
        </div>
        <div class="topbar-right"><%- typeof topbarRight !== "undefined" ? topbarRight : "" %></div>
      </div>

      <div class="content-body">
        <% if (flash) { %>
          <div class="alert-toast alert-<%= flash.type %>"><%= flash.text %></div>
        <% } %>

        <%- body %>
      </div>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
